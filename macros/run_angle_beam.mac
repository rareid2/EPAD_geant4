# Macro file for running one particle beam

/run/numberOfThreads 40 
/run/initialize 
/control/verbose 0 
/run/verbose 0 
/event/verbose 0 
/tracking/verbose 0 

# General Particle Source:
/gps/particle e-
/gps/position 0 0 -500 cm
/gps/pos/type Point
/gps/direction 0 0 1
/gps/energy 450 keV

/run/beamOn 1